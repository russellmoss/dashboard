    <recordLookups>
        <description>Gets leads to recycle based on the recycle-able leads report. The logic is:
1. Not in Qualified or Nurture
2. In the last 90 days there has been no activity, the prospect has not been put in contacting, replied, or call scheduled
3. It has not been marked do not call
4. It has not been marked Not a fit
5. It has not been created within 90 days</description>
        <name>Get_Recycleable_Leads</name>
        <label>Get Recycleable Leads</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Add_Disposition_and_Change_Owner</targetReference>
        </connector>
        <filterLogic>1 AND 2 AND (3 OR 4) AND (5 OR 6) AND (7 OR 8) AND (9 OR 10) AND 11 AND 12 AND 13 AND 14 AND (15 OR 16 OR 17 OR 18 OR 19 OR 20 OR 21 OR 22) AND (23 OR 24)</filterLogic>
        <filters>
            <field>Status</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Qualified</stringValue>
            </value>
        </filters>
        <filters>
            <field>Status</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Nurture</stringValue>
            </value>
        </filters>
        <filters>
            <field>LastActivityDate</field>
            <operator>LessThanOrEqualTo</operator>
            <value>
                <elementReference>Last90Days</elementReference>
            </value>
        </filters>
        <filters>
            <field>LastActivityDate</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Stage_Entered_Call_Scheduled__c</field>
            <operator>LessThanOrEqualTo</operator>
            <value>
                <elementReference>Last90Days</elementReference>
            </value>
        </filters>
        <filters>
            <field>Stage_Entered_Call_Scheduled__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Stage_Entered_Contacting__c</field>
            <operator>LessThanOrEqualTo</operator>
            <value>
                <elementReference>Last90Days</elementReference>
            </value>
        </filters>
        <filters>
            <field>Stage_Entered_Contacting__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Stage_Entered_Replied__c</field>
            <operator>LessThanOrEqualTo</operator>
            <value>
                <elementReference>Last90Days</elementReference>
            </value>
        </filters>
        <filters>
            <field>Stage_Entered_Replied__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>DoNotCall</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Disposition__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Not a Fit</stringValue>
            </value>
        </filters>
        <filters>
            <field>OwnerId</field>
            <operator>NotEqualTo</operator>
            <value>
                <elementReference>SavvyOperationsUser</elementReference>
            </value>
        </filters>
        <filters>
            <field>CreatedDate</field>
            <operator>LessThanOrEqualTo</operator>
            <value>
                <elementReference>Last90Days</elementReference>
            </value>
        </filters>
        <filters>
            <field>Disposition__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Bad Contact Info - Uncontacted</stringValue>
            </value>
        </filters>
        <filters>
            <field>Disposition__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>No Response</stringValue>
            </value>
        </filters>
        <filters>
            <field>Disposition__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>No Show / Ghosted</stringValue>
            </value>
        </filters>
        <filters>
            <field>Disposition__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Not Interested in Moving</stringValue>
            </value>
        </filters>
        <filters>
            <field>Disposition__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Timing</stringValue>
            </value>
        </filters>
        <filters>
            <field>Disposition__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Wrong Phone Number - Contacted</stringValue>
            </value>
        </filters>
        <filters>
            <field>Disposition__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Other</stringValue>
            </value>
        </filters>
        <filters>
            <field>Disposition__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue></stringValue>
            </value>
        </filters>
        <filters>
            <field>Lead_Reassignment_Date__c</field>
            <operator>LessThanOrEqualTo</operator>
            <value>
                <elementReference>Last90Days</elementReference>
            </value>
        </filters>
        <filters>
            <field>Lead_Reassignment_Date__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>Lead</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
