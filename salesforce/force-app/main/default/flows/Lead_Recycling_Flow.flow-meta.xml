    <decisions>
        <name>If_a_Weekend_Do_Nothing</name>
        <label>If a Weekend, Do Nothing</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Get_Recycleable_Leads</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Weekday</defaultConnectorLabel>
        <rules>
            <name>Weekend</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>WeekdayName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>1.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>WeekdayName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>7.0</numberValue>
                </rightValue>
            </conditions>
            <label>Weekend</label>
        </rules>
    </decisions>
    <decisions>
        <name>If_Still_Open</name>
        <label>If Still Open</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Add_Lead_to_Overall_Recycling</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Is Already Closed</defaultConnectorLabel>
        <rules>
            <name>Is_Still_Open</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Add_Disposition_and_Change_Owner.Status</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Closed</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Disposition_for_Open_Leads</targetReference>
            </connector>
            <label>Is Still Open</label>
        </rules>
    </decisions>
    <description>A daily flow which moves recyclable leads to the Savvy Operations user. 8/4 Update to be done using collections</description>
    <environments>Default</environments>
    <formulas>
        <description>Today&apos;s date - 90 days</description>
        <name>Last90Days</name>
        <dataType>Date</dataType>
        <expression>{!$Flow.CurrentDate}-90</expression>
    </formulas>
    <formulas>
        <name>WeekdayName</name>
        <dataType>Number</dataType>
        <expression>WEEKDAY({!$Flow.CurrentDate})</expression>
        <scale>0</scale>
    </formulas>
