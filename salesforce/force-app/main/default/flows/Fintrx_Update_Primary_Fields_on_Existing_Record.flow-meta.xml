<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <description>The flow which runs when an existing prospect is updated through the Fintrx API</description>
    <environments>Default</environments>
    <interviewLabel>Fintrx - Update Primary Fields on Existing Record {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Fintrx - Update Primary Fields on Existing Record</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Update_Matching_Fields_on_Record</name>
        <label>Update Matching Fields on Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>Final_Source__c</field>
            <value>
                <stringValue>Fintrx (Self-Sourced)</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Finance_View__c</field>
            <value>
                <stringValue>Outbound</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>FirstName</field>
            <value>
                <elementReference>$Record.Fintrx_First_Name__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>LeadSource</field>
            <value>
                <stringValue>Fintrx (Self-Sourced)</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>LinkedIn_Profile_Apollo__c</field>
            <value>
                <elementReference>$Record.Fintrx_LinkedIn_URL__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>MobilePhone</field>
            <value>
                <elementReference>$Record.Fintrx_Mobile_Phone__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Mobile_Phone_2__c</field>
            <value>
                <elementReference>$Record.Fintrx_Additional_Phone__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Primary_Email__c</field>
            <value>
                <elementReference>$Record.Fintrx_Personal_Email__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Title</field>
            <value>
                <elementReference>$Record.Fintrx_Title__c</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Matching_Fields_on_Record</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Fintrx_Dataset__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <object>Lead</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Draft</status>
</Flow>
