<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Signed_Previous_Custodian</fullName>
    <active>true</active>
    <description>Require a Previous Custodian to move to Signed.</description>
    <errorConditionFormula>AND ( RecordTypeId = &apos;012Dn000000mrO3IAI&apos;,
     OR(ISPICKVAL(StageName, &quot;Joined&quot;),
        ISPICKVAL(StageName, &quot;Signed&quot;)
     ),
     ISBLANK(Previous_Custodians__c)

)</errorConditionFormula>
    <errorDisplayField>Previous_Custodians__c</errorDisplayField>
    <errorMessage>Please add a previous custodian before marking this advisor as signed.</errorMessage>
</ValidationRule>
