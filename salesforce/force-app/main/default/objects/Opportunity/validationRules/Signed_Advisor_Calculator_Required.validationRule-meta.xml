<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Signed_Advisor_Calculator_Required</fullName>
    <active>true</active>
    <description>An Advisor Offer Calculator URL is required to move to Signed or Joined.</description>
    <errorConditionFormula>AND ( ISCHANGED(StageName),
     OR(ISPICKVAL(StageName, &quot;Joined&quot;),
        ISPICKVAL(StageName, &quot;Signed&quot;)
     ),
        ISBLANK(Advisor_Offer_Calculator_URL__c)
)</errorConditionFormula>
    <errorDisplayField>Advisor_Offer_Calculator_URL__c</errorDisplayField>
    <errorMessage>An Advisor Offer Calculator URL is required to move to Signed or Joined.</errorMessage>
</ValidationRule>
