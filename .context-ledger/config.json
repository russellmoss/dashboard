{
  "capture": {
    "enabled": true,
    "ignore_paths": [
      "dist/",
      "node_modules/",
      ".next/",
      "coverage/",
      ".agent-guard/"
    ],
    "scope_mappings": {
      "src/lib/queries/": { "type": "domain", "id": "query-layer" },
      "src/lib/utils/": { "type": "domain", "id": "utilities" },
      "src/lib/sheets/": { "type": "domain", "id": "sheets-export" },
      "src/lib/semantic-layer/": { "type": "domain", "id": "semantic-layer" },
      "src/types/": { "type": "concern", "id": "type-definitions" },
      "src/app/api/": { "type": "domain", "id": "api-routes" },
      "src/components/": { "type": "domain", "id": "components" },
      "src/app/dashboard/": { "type": "domain", "id": "dashboard-pages" }
    },
    "redact_patterns": [],
    "no_capture_marker": "[no-capture]",
    "inbox_ttl_days": 14,
    "inbox_max_prompts_per_item": 3,
    "inbox_max_items_per_session": 3
  },
  "retrieval": {
    "default_limit": 20,
    "include_superseded": false,
    "include_unreviewed": false,
    "auto_promotion_min_weight": 0.7,
    "token_budget": 4000,
    "feature_hint_mappings": {
      "drill-down": ["query-layer"],
      "export": ["sheets-export"],
      "csv": ["sheets-export"],
      "sheets": ["sheets-export"],
      "pipeline": ["query-layer"],
      "forecast": ["query-layer"],
      "explore": ["semantic-layer"],
      "SGA": ["components"],
      "SGM": ["components"],
      "type": ["type-definitions"],
      "bigquery": ["query-layer"]
    }
  },
  "workflow_integration": {
    "selective_writeback": true,
    "check_inbox_on_session_start": true,
    "jit_backfill": true
  },
  "monorepo": {
    "package_name": null,
    "root_relative_path": null
  }
}
