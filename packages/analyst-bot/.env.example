# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...

# Claude
ANTHROPIC_API_KEY=sk-ant-...

# schema-context-mcp remote server
MCP_SERVER_URL=https://savvy-mcp-server-e2vyxy5ipa-ue.a.run.app/mcp
MCP_API_KEY=sk-savvy-...

# Neon Postgres
DATABASE_URL=postgresql://...?sslmode=require

# BigQuery
BIGQUERY_PROJECT=savvy-gtm-analytics
AUDIT_DATASET=bot_audit
AUDIT_TABLE=interaction_log

# Bot config
ALLOWED_CHANNELS=C01ABC,C02DEF
ISSUES_CHANNEL=C03GHI
MAINTAINER_SLACK_ID=U04JKL
CLEANUP_SECRET=a-random-secret-for-cloud-scheduler

# Upstash Redis — distributed dedup + rate limiting
# Required for multi-instance Cloud Run. Falls back to in-memory if unset.
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Google Docs / Drive — service account credentials (stringified JSON or individual fields)
GOOGLE_DOCS_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Cron endpoint security
CRON_SECRET=a-random-32-char-hex-for-cloud-scheduler

# Admin — comma-separated Slack user IDs who see the admin App Home view
ADMIN_SLACK_USER_IDS=U09DX3U7UTW
