generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  engineType    = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                @id @default(cuid())
  email               String                @unique
  name                String
  passwordHash        String?
  role                String                @default("viewer")
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  createdBy           String?
  isActive            Boolean               @default(true)
  externalAgency      String?
  submittedRequests   DashboardRequest[]    @relation("SubmittedRequests")
  gameScores          GameScore[]
  passwordResetTokens PasswordResetToken[]
  reportJobs          ReportJob[]
  reportShares        ReportShare[]         @relation("ReportShareRecipient")
  uploadedAttachments RequestAttachment[]   @relation("UploadedAttachments")
  requestComments     RequestComment[]      @relation("RequestComments")
  requestEdits        RequestEditHistory[]  @relation("RequestEdits")
  notifications       RequestNotification[] @relation("UserNotifications")
  savedReports        SavedReport[]
  forecastScenarios   ForecastScenario[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model WeeklyGoal {
  id                     String   @id @default(cuid())
  userEmail              String
  weekStartDate          DateTime @db.Date
  initialCallsGoal       Int      @default(0)
  qualificationCallsGoal Int      @default(0)
  sqoGoal                Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  createdBy              String?
  updatedBy              String?
  mqlGoal                Int      @default(0)
  sqlGoal                Int      @default(0)
  leadsSourcedGoal       Int      @default(0)
  leadsContactedGoal     Int      @default(0)

  @@unique([userEmail, weekStartDate])
  @@index([userEmail])
  @@index([weekStartDate])
}

model QuarterlyGoal {
  id        String   @id @default(cuid())
  userEmail String
  quarter   String
  sqoGoal   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([userEmail, quarter])
  @@index([userEmail])
  @@index([quarter])
}

model ManagerQuarterlyGoal {
  id        String   @id @default(cuid())
  quarter   String   @unique
  sqoGoal   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  @@index([quarter])
  @@map("manager_quarterly_goals")
}

model ForecastQuarterTarget {
  id               String   @id @default(cuid())
  quarter          String   @unique
  targetAumDollars Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  updatedBy        String?

  @@index([quarter])
  @@map("forecast_quarter_targets")
}

model ForecastExport {
  id             String   @id @default(cuid())
  spreadsheetId  String
  spreadsheetUrl String
  name           String
  createdAt      DateTime @default(now())
  createdBy      String
  windowDays     Int?
  p2RowCount     Int      @default(0)
  auditRowCount  Int      @default(0)

  @@index([createdBy])
  @@map("forecast_exports")
}

model ExploreFeedback {
  id            String   @id @default(cuid())
  userId        String?
  question      String
  questionId    String
  templateId    String
  feedback      String
  comment       String?
  createdAt     DateTime @default(now())
  compiledQuery Json?
  resultSummary Json?
  error         String?
  executableSql String?

  @@index([userId])
  @@index([templateId])
  @@index([feedback])
  @@index([createdAt])
  @@index([error])
}

model GameScore {
  id             String   @id @default(cuid())
  userId         String
  score          BigInt
  advisorsCaught Int
  joinedCaught   Int
  ghostsHit      Int
  quarter        String
  gameDuration   Int
  message        String?  @db.VarChar(100)
  playedAt       DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([quarter, score(sort: Desc)])
  @@index([userId])
  @@index([playedAt])
}

model SavedReport {
  id               String   @id @default(cuid())
  userId           String?
  name             String   @db.VarChar(255)
  description      String?  @db.VarChar(500)
  filters          Json
  featureSelection Json?
  viewMode         String?  @default("focused")
  dashboard        String   @default("funnel_performance")
  reportType       String   @default("user")
  isDefault        Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  createdBy        String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([reportType])
  @@index([isDefault])
  @@index([isActive])
  @@index([dashboard])
}

model DashboardRequest {
  id              String                @id @default(cuid())
  title           String
  description     String
  requestType     RequestType
  status          RequestStatus         @default(SUBMITTED)
  priority        RequestPriority?
  affectedPage    String?
  filtersApplied  String?
  valueSeen       String?
  valueExpected   String?
  errorOccurredAt DateTime?
  isPrivate       Boolean               @default(false)
  wrikeTaskId     String?               @unique
  wrikePermalink  String?
  lastSyncedAt    DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  statusChangedAt DateTime              @default(now())
  submitterId     String
  submitter       User                  @relation("SubmittedRequests", fields: [submitterId], references: [id])
  attachments     RequestAttachment[]
  comments        RequestComment[]
  editHistory     RequestEditHistory[]
  notifications   RequestNotification[]

  @@index([submitterId])
  @@index([status])
  @@index([requestType])
  @@index([wrikeTaskId])
}

model RequestComment {
  id             String           @id @default(cuid())
  content        String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  requestId      String
  authorId       String
  wrikeCommentId String?          @unique
  author         User             @relation("RequestComments", fields: [authorId], references: [id])
  request        DashboardRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([authorId])
}

model RequestAttachment {
  id                String           @id @default(cuid())
  filename          String
  mimeType          String
  size              Int
  wrikeAttachmentId String?          @unique
  wrikeDownloadUrl  String?
  createdAt         DateTime         @default(now())
  requestId         String
  uploadedById      String
  data              String?
  request           DashboardRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  uploadedBy        User             @relation("UploadedAttachments", fields: [uploadedById], references: [id])

  @@index([requestId])
}

model RequestEditHistory {
  id         String           @id @default(cuid())
  fieldName  String
  oldValue   String?
  newValue   String?
  createdAt  DateTime         @default(now())
  requestId  String
  editedById String
  editedBy   User             @relation("RequestEdits", fields: [editedById], references: [id])
  request    DashboardRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model RequestNotification {
  id        String           @id @default(cuid())
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  requestId String
  userId    String
  request   DashboardRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user      User             @relation("UserNotifications", fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([requestId])
}

model AdvisorAddressOverride {
  id         String   @id @default(cuid())
  primaryKey String   @unique
  street1    String?
  street2    String?
  city       String?
  state      String?
  postalCode String?
  country    String?
  lat        Float?
  lng        Float?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String

  @@index([primaryKey])
  @@index([createdAt])
  @@map("advisor_address_overrides")
}

model GcAdvisorPeriodData {
  id                      String    @id @default(cuid())
  advisorNormalizedName   String
  orionRepresentativeId   String?
  accountName             String?
  period                  String
  periodStart             DateTime  @db.Date
  grossRevenue            Float?
  commissionsPaid         Float?
  amountEarned            Float?
  aum                     Float?
  billingFrequency        String?
  billingStyle            String?
  sourceWorkbookId        String?
  sourceTab               String?
  dataSource              String    @default("historical_etl")
  isManuallyOverridden    Boolean   @default(false)
  originalGrossRevenue    Float?
  originalCommissionsPaid Float?
  overrideReason          String?
  overriddenBy            String?
  overriddenAt            DateTime?
  importedAt              DateTime  @default(now())
  lastSyncedAt            DateTime?

  @@unique([advisorNormalizedName, period])
  @@index([advisorNormalizedName])
  @@index([period])
  @@index([periodStart])
  @@index([accountName])
  @@index([dataSource])
  @@index([orionRepresentativeId])
}

model GcAdvisorMapping {
  id                    String   @id @default(cuid())
  advisorNormalizedName String   @unique
  orionRepresentativeId String?  @unique
  accountName           String?
  anonymousAdvisorId    String   @unique
  anonymousAccountName  String?
  billingFrequency      String?
  billingStyle          String?
  billingType           String?
  glTreatment           String?
  isChurned             Boolean  @default(false)
  isExcluded            Boolean  @default(false)
  exclusionReason       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([accountName])
  @@index([isExcluded])
}

model GcSyncLog {
  id               String    @id @default(cuid())
  syncType         String
  sourceWorkbookId String?
  status           String
  recordsProcessed Int       @default(0)
  recordsInserted  Int       @default(0)
  recordsUpdated   Int       @default(0)
  recordsSkipped   Int       @default(0)
  errorMessage     String?
  errorDetails     Json?
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  triggeredBy      String?

  @@index([syncType])
  @@index([status])
  @@index([startedAt])
}

model ReportJob {
  id                 String               @id @default(cuid())
  type               String
  status             String               @default("pending")
  requestedById      String
  customPrompt       String?
  parameters         Json?
  reportJson         Json?
  queryLog           Json?
  extractedMetrics   Json?
  verificationResult Json?
  visibility         String               @default("private")
  stepsCompleted     Int                  @default(0)
  totalTokens        Int?
  durationMs         Int?
  error              String?
  promptVersion      String?
  createdAt          DateTime             @default(now())
  completedAt        DateTime?
  conversations      ReportConversation[]
  requestedBy        User                 @relation(fields: [requestedById], references: [id])
  sharedWith         ReportShare[]

  @@index([type, requestedById, createdAt(sort: Desc)])
  @@index([requestedById])
  @@index([status])
  @@index([type])
}

model ReportShare {
  id           String    @id @default(cuid())
  reportId     String
  sharedWithId String
  createdAt    DateTime  @default(now())
  report       ReportJob @relation(fields: [reportId], references: [id], onDelete: Cascade)
  sharedWith   User      @relation("ReportShareRecipient", fields: [sharedWithId], references: [id])

  @@unique([reportId, sharedWithId])
  @@index([reportId])
  @@index([sharedWithId])
}

model ReportConversation {
  id        String    @id @default(cuid())
  reportId  String
  role      String
  content   String
  createdAt DateTime  @default(now())
  report    ReportJob @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, createdAt])
}

model Forecast {
  id                 String               @id
  quarter            String               @unique
  year               Int
  status             ForecastStatus       @default(DRAFT)
  notes              String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  createdBy          String?
  updatedBy          String?
  ForecastAssumption ForecastAssumption[]
  ForecastLineItem   ForecastLineItem[]
  ForecastRateItem   ForecastRateItem[]
  ForecastSource     ForecastSource[]
  ForecastTarget     ForecastTarget[]

  @@index([quarter])
  @@index([status])
}

model ForecastAssumption {
  id              String   @id
  forecastId      String
  channel         String?
  subSource       String?
  month           String?
  assumptionKey   String
  assumptionValue String
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  updatedBy       String?
  Forecast        Forecast @relation(fields: [forecastId], references: [id], onDelete: Cascade)

  @@unique([forecastId, channel, subSource, month, assumptionKey], map: "ForecastAssumption_forecastId_channel_subSource_month_assumptio")
  @@index([forecastId])
}

model ForecastLineItem {
  id               String             @id
  forecastId       String
  channel          String
  subSource        String
  month            String
  stage            FunnelStage
  calculatedVolume Int                @default(0)
  finalVolume      Int                @default(0)
  isLocked         Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  Forecast         Forecast           @relation(fields: [forecastId], references: [id], onDelete: Cascade)
  ForecastOverride ForecastOverride[]

  @@unique([forecastId, subSource, month, stage])
  @@index([channel])
  @@index([forecastId])
  @@index([month])
  @@index([subSource])
}

model ForecastOverride {
  id               String            @id
  lineItemId       String?
  rateItemId       String?
  fieldType        String
  originalValue    Float
  overrideValue    Float
  reason           String
  overriddenBy     String
  createdAt        DateTime          @default(now())
  ForecastLineItem ForecastLineItem? @relation(fields: [lineItemId], references: [id], onDelete: Cascade)
  ForecastRateItem ForecastRateItem? @relation(fields: [rateItemId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([lineItemId])
  @@index([overriddenBy])
  @@index([rateItemId])
}

model ForecastRateItem {
  id               String             @id
  forecastId       String
  channel          String
  subSource        String
  month            String
  transition       StageTransition
  calculatedRate   Float              @default(0)
  finalRate        Float              @default(0)
  isLocked         Boolean            @default(false)
  rateSource       String             @default("calculated")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  ForecastOverride ForecastOverride[]
  Forecast         Forecast           @relation(fields: [forecastId], references: [id], onDelete: Cascade)

  @@unique([forecastId, subSource, month, transition])
  @@index([channel])
  @@index([forecastId])
  @@index([subSource])
}

model ForecastSource {
  id         String   @id
  forecastId String
  subSource  String
  channel    String
  isActive   Boolean  @default(true)
  isManual   Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Forecast   Forecast @relation(fields: [forecastId], references: [id], onDelete: Cascade)

  @@unique([forecastId, subSource])
  @@index([channel])
  @@index([forecastId])
}

model ForecastTarget {
  id                  String      @id
  forecastId          String
  channel             String
  month               String
  stage               FunnelStage
  minimumForecast     Int         @default(0)
  financeMinimum      Int         @default(0)
  gapFillerAllocation Int         @default(0)
  comments            String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime
  updatedBy           String?
  Forecast            Forecast    @relation(fields: [forecastId], references: [id], onDelete: Cascade)

  @@unique([forecastId, channel, month, stage])
  @@index([channel])
  @@index([forecastId])
}

model SGMQuarterlyGoal {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  userEmail String
  quarter   String
  arrGoal   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime
  createdBy String?
  updatedBy String?

  @@unique([userEmail, quarter])
  @@index([quarter])
  @@index([userEmail])
}

enum RequestStatus {
  SUBMITTED
  PLANNED
  IN_PROGRESS
  DONE
  ARCHIVED
}

enum RequestType {
  FEATURE_REQUEST
  DATA_ERROR
}

enum RequestPriority {
  LOW
  MEDIUM
  HIGH
  IMMEDIATE
}

enum ForecastStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum FunnelStage {
  CREATED
  CONTACTED
  MQL
  SQL
  SQO
  JOINED
}

enum StageTransition {
  CREATED_TO_CONTACTED
  CONTACTED_TO_MQL
  MQL_TO_SQL
  SQL_TO_SQO
  SQO_TO_JOINED
}

model ForecastScenario {
  id                  String   @id @default(cuid())
  name                String
  description         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdById         String
  createdByName       String
  conversionWindowDays Int?
  isBaseForecast      Boolean  @default(false)

  // Rate overrides (decimals 0.0–1.0, NOT percentages)
  rateOverride_sqo_to_sp        Float
  rateOverride_sp_to_neg        Float
  rateOverride_neg_to_signed    Float
  rateOverride_signed_to_joined Float

  // Avg days overrides
  avgDaysOverride_in_sp     Float
  avgDaysOverride_in_neg    Float
  avgDaysOverride_in_signed Float

  // Historical rates snapshot (audit trail)
  historicalRate_sqo_to_sp        Float
  historicalRate_sp_to_neg        Float
  historicalRate_neg_to_signed    Float
  historicalRate_signed_to_joined Float

  // Monte Carlo results summary
  trialCount       Int     @default(5000)
  quartersJson     Json?   // Array of { label, p10, p50, p90, mean }

  // Pipeline snapshot metadata
  pipelineOppCount Int?
  pipelineTotalAum Float?

  // Sharing
  shareToken String  @unique @default(cuid())
  isPublic   Boolean @default(false)

  // Per-opp results (JSON blob, ~30KB per scenario)
  perOppResults Json?

  // Relation to User
  createdBy User @relation(fields: [createdById], references: [id])

  @@index([createdById])
  @@index([shareToken])
  @@index([createdAt])
}
